# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=taskboard
DB_PASSWORD=taskboard
DB_NAME=taskboard

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Static files directory (contains index.html)
STATIC_DIR=./static

# Swagger UI — set to "false" to disable
ENABLE_DOCS=true

# Number of taps/clicks to delete a box (requires restart)
DELETE_TAP_COUNT=3

# Move Add/Manage controls to a dedicated tab instead of the toolbar.
# Set to "true" for touch-only display devices (tablets, small screens).
SEPARATE_ADD_TAB=false

# Default canvas dimensions for new box placement (pixels)
DEFAULT_CANVAS_WIDTH=1280
DEFAULT_CANVAS_HEIGHT=800

# Log level
RUST_LOG=info
